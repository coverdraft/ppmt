# ─── PPMT Trading Terminal — Environment Variables ──────────────────

# Prisma database (sqlite by default)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Trading Bridge (Socket.io ↔ Python PPMT engine) ────────────────
# Leave UNSET to run the terminal in pure demo mode (no socket attempts,
# no console spam). Set this ONLY when you also start the bridge:
#
#   pnpm dev:bridge
#
# The bridge listens on port 3003 and proxies to the Python V2 server.
NEXT_PUBLIC_BRIDGE_URL=http://localhost:3003

# ─── Python PPMT V2 Backend (used by the bridge) ────────────────────
# Only used by mini-services/trading-bridge/index.ts
PPMT_WS_URL=ws://127.0.0.1:8000
