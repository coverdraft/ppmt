# PPMT Configuration
# Copy to .env and adjust for your setup

# Data Collection
EXCHANGE=binance
API_KEY=
API_SECRET=

# Engine Configuration
SAX_WORD_LENGTH=8
SAX_SEGMENT_SIZE=6
SAX_ALPHABET_SIZE=8

# Risk Management
RISK_PER_TRADE=0.02
MAX_DAILY_DRAWDOWN=0.05
MAX_CORRELATED_POSITIONS=3
INITIAL_CAPITAL=10000

# Asset Classes
N4_MIN_PATTERNS=5000
N3_MIN_PATTERNS=30000

# Signal Thresholds
MIN_CONFIDENCE=0.60
MIN_CONSENSUS_LEVELS=2
