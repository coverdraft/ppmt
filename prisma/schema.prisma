generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER MODEL - Authentication & Multi-user
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  image         String?
  role          String   @default("USER")  // "USER" | "ADMIN"
  passwordHash  String   @default("")      // bcrypt hash for credentials provider
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations — user owns their data
  tradingSystems       TradingSystem[]
  backtestRuns         BacktestRun[]
  paperTradingSessions PaperTradingSession[]
  paperTradingPositions PaperTradingPosition[]
  alertRules           AlertRule[]
  alerts               Alert[]
  webhookConfigs       WebhookConfig[]
  strategyTemplates    StrategyTemplate[]  // User-created templates

  @@map("users")
}

// ============================================================
// TOKEN MODELS - Multi-chain token tracking
// ============================================================

model Token {
  id              String   @id @default(cuid())
  symbol          String
  name            String
  address         String   @unique
  chain           String   @default("SOL")
  priceUsd        Float    @default(0)
  volume24h       Float    @default(0)
  liquidity       Float    @default(0)
  marketCap       Float    @default(0)
  priceChange5m   Float    @default(0)
  priceChange15m  Float    @default(0)
  priceChange1h   Float    @default(0)
  priceChange6h   Float    @default(0)
  priceChange24h  Float    @default(0)
  
  // DEX Metadata
  dexId           String?  // DexScreener pair ID
  pairAddress     String?  // LP pair address
  dex             String?  // raydium, uniswap, orca, jupiter, etc
  pairUrl         String?  // Link to DEX page
  
  // Enriched Metrics
  holderCount     Int      @default(0)
  uniqueWallets24h Int     @default(0)
  botActivityPct  Float    @default(0)  // % of volume from identified bots
  smartMoneyPct   Float    @default(0)  // % of volume from smart money
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  dna             TokenDNA?
  signals         Signal[]
  candles         PriceCandle[]
  lifecycleStates TokenLifecycleState[]
}

// ============================================================
// TRADER INTELLIGENCE - Core wallet profiling system
// ============================================================

model Trader {
  id              String   @id @default(cuid())
  address         String   @unique
  chain           String   @default("SOL")
  ensName         String?  // ENS for ETH wallets
  solName         String?  // .sol domain for Solana wallets
  
  // === CLASSIFICATION ===
  primaryLabel    String   @default("UNKNOWN")
  // Possible: SMART_MONEY, WHALE, SNIPER, BOT_MEV, BOT_SNIPER, BOT_COPY,
  //           BOT_ARBITRAGE, BOT_LIQUIDATION, BOT_WASH, BOT_MAKER,
  //           BOT_SCALPER, RETAIL, CREATOR, FUND, INFLUENCER, BRIDGE_HOPPER,
  //           YIELD_FARMER, AIRDROP_HUNTER, NFT_FLIPPER, UNKNOWN
  subLabels       String   @default("[]")  // JSON array of additional labels
  labelConfidence Float    @default(0)     // 0-1 confidence in primary classification
  
  // === BOT DETECTION ===
  isBot           Boolean  @default(false)
  botType         String?
  // Possible: MEV_EXTRACTOR, SNIPER_BOT, COPY_BOT, ARBITRAGE_BOT,
  //           SANDWICH_BOT, WASH_TRADING_BOT, LIQUIDATION_BOT,
  //           MARKET_MAKER_BOT, SCALPER_BOT, FRONT_RUN_BOT,
  //           JUST_IN_TIME_BOT, JITO_BOT, MULTI_SIG_BOT
  botConfidence   Float    @default(0)     // 0-1 confidence in bot classification
  botDetectionSignals String @default("[]") // JSON: signals that triggered bot detection
  botDetectionVersion String @default("1.0")
  botFirstDetectedAt  DateTime?
  
  // === PERFORMANCE METRICS ===
  totalTrades     Int      @default(0)
  winRate         Float    @default(0)     // 0-1
  avgPnl          Float    @default(0)     // average PnL per trade in USD
  totalPnl        Float    @default(0)     // cumulative realized PnL in USD
  avgHoldTimeMin  Float    @default(0)     // average hold time in minutes
  avgTradeSizeUsd Float    @default(0)
  largestTradeUsd Float    @default(0)
  totalVolumeUsd  Float    @default(0)
  maxDrawdown     Float    @default(0)     // worst peak-to-trough in USD
  sharpeRatio     Float    @default(0)     // risk-adjusted return
  profitFactor    Float    @default(0)     // gross profit / gross loss
  
  // === BEHAVIORAL METRICS ===
  avgSlippageBps  Int      @default(0)     // average slippage in basis points
  frontrunCount   Int      @default(0)     // times this wallet frontran others
  frontrunByCount Int      @default(0)     // times this wallet was frontrun
  sandwichCount   Int      @default(0)     // times involved in sandwich attacks
  sandwichVictimCount Int  @default(0)     // times victim of sandwich
  washTradeScore  Float    @default(0)     // 0-1, higher = more likely wash trading
  copyTradeScore  Float    @default(0)     // 0-1, how much this wallet copies others
  mevExtractionUsd Float   @default(0)     // total MEV extracted in USD
  
  // === TIMING PATTERNS ===
  avgTimeBetweenTrades Float @default(0)   // minutes
  tradingHourPattern   String @default("[]") // JSON: 24-element array, trade frequency per hour UTC
  tradingDayPattern    String @default("[]") // JSON: 7-element array, trade frequency per day
  isActiveAtNight      Boolean @default(false) // trades during off-hours (bot indicator)
  isActive247          Boolean @default(false) // trades all hours consistently (strong bot signal)
  consistencyScore     Float  @default(0)    // 0-1, how consistent the trading intervals are
  
  // === PORTFOLIO PROFILE ===
  uniqueTokensTraded Int    @default(0)
  avgPositionsAtOnce Int    @default(0)
  maxPositionsAtOnce Int    @default(0)
  preferredChains    String @default("[]") // JSON array of chains this trader uses
  preferredDexes     String @default("[]") // JSON array of DEXes this trader uses
  preferredTokenTypes String @default("[]") // JSON: MEME, DEFI, NFT, L1, L2, STABLE, BRIDGE
  
  // === SMART MONEY SPECIFIC ===
  isSmartMoney      Boolean @default(false)
  smartMoneyScore   Float   @default(0)    // 0-100 composite score
  earlyEntryCount   Int     @default(0)    // times entered before token did 10x
  avgEntryRank      Float   @default(0)    // average rank of entry (1 = first buyer)
  avgExitMultiplier Float   @default(0)    // average multiplier at exit
  topCallCount      Int     @default(0)    // number of profitable calls
  worstCallCount    Int     @default(0)    // number of losing calls
  
  // === WHALE SPECIFIC ===
  isWhale           Boolean @default(false)
  whaleScore        Float   @default(0)    // 0-100 based on total holdings + influence
  totalHoldingsUsd  Float   @default(0)
  avgPositionUsd    Float   @default(0)
  priceImpactAvg    Float   @default(0)    // average price impact of trades
  
  // === SNIPER SPECIFIC ===
  isSniper          Boolean @default(false)
  sniperScore       Float   @default(0)    // 0-100
  avgBlockToTrade   Float   @default(0)    // average blocks between token creation and first trade
  block0EntryCount  Int     @default(0)    // times bought in block 0 or 1 of a token
  
  // === RELATIONSHIPS & META ===
  firstSeen        DateTime @default(now())
  lastActive       DateTime @default(now())
  lastAnalyzed     DateTime @default(now())
  analysisVersion  Int      @default(1)
  dataQuality      Float    @default(0)    // 0-1, how complete our data is for this trader
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // Relations
  transactions     TraderTransaction[]
  tokenHoldings    WalletTokenHolding[]
  behaviorPatterns TraderBehaviorPattern[]
  crossChainLinks  CrossChainWallet[]  @relation("PrimaryWallet")
  linkedWallets    CrossChainWallet[]  @relation("LinkedWallet")
  labelAssignments TraderLabelAssignment[]
}

model TraderTransaction {
  id              String   @id @default(cuid())
  traderId        String
  txHash          String   @unique
  blockNumber     Int?
  blockTime       DateTime
  
  // Transaction Details
  chain           String   @default("SOL")
  dex             String?  // raydium, uniswap, orca, jupiter, meteora, etc
  action          String   // BUY, SELL, TRANSFER, ADD_LIQUIDITY, REMOVE_LIQUIDITY, SWAP
  tokenAddress    String   // token being traded
  tokenSymbol     String?
  quoteToken      String?  // SOL, USDC, ETH, WETH, USDT
  amountIn        Float    @default(0)
  amountOut       Float    @default(0)
  priceUsd        Float    @default(0)
  valueUsd        Float    @default(0)
  
  // === ANTI-MEV / BOT ANALYSIS ===
  slippageBps     Int?     // actual slippage experienced in basis points
  pnlUsd          Float?   // realized PnL if closing trade
  isFrontrun      Boolean  @default(false)
  isSandwich      Boolean  @default(false)
  isWashTrade     Boolean  @default(false)
  isJustInTime    Boolean  @default(false) // JIT liquidity provision
  pairedTxHash    String?  // linked tx (e.g., other side of sandwich)
  
  // === GAS & FEES ===
  gasUsed         Float?
  gasPrice        Float?
  priorityFee     Float?   // tip/priority fee (Jito tip on Solana, etc)
  totalFeeUsd     Float?   // total cost including gas + fees
  
  // === TOKEN CONTEXT ===
  tokenAgeAtTrade Float?   // minutes since token creation at time of trade
  holderCountAtTrade Int?  // number of holders when this trade occurred
  liquidityAtTrade Float?  // available liquidity when this trade occurred
  
  // Metadata
  logIndex        Int?
  metadata        String   @default("{}")
  
  trader          Trader   @relation(fields: [traderId], references: [id])
  createdAt       DateTime @default(now())
}

model WalletTokenHolding {
  id              String   @id @default(cuid())
  traderId        String
  tokenAddress    String
  tokenSymbol     String?
  chain           String   @default("SOL")
  
  balance         Float    @default(0)
  valueUsd        Float    @default(0)
  avgEntryPrice   Float    @default(0)
  unrealizedPnl   Float    @default(0)
  unrealizedPnlPct Float   @default(0)
  
  firstBuyAt      DateTime?
  lastTradeAt     DateTime?
  buyCount        Int      @default(0)
  sellCount       Int      @default(0)
  totalBoughtUsd  Float    @default(0)
  totalSoldUsd    Float    @default(0)
  
  trader          Trader   @relation(fields: [traderId], references: [id])
  updatedAt       DateTime @updatedAt
}

model TraderBehaviorPattern {
  id              String   @id @default(cuid())
  traderId        String
  
  pattern         String
  // Possible: ACCUMULATOR, DUMPER, SCALPER, SWING_TRADER, DIAMOND_HANDS,
  //           MOMENTUM_RIDER, CONTRARIAN, SNIPER_ENTRY, EXIT_SCAMMER,
  //           WASH_TRADER, COPY_CAT, YIELD_FARMER, BRIDGE_HOPPER,
  //           LIQUIDITY_PROVIDER, MEV_EXTRACTOR, SANDWICH_ATTACKER,
  //           JUST_IN_TIME_LP, FLASH_LOAN_USER, AIRDROP_FARMER,
  //           DEX_AGREGATOR_USER, JITO_TIP_USER, MULTI_HOP_SWAPPER
  
  confidence      Float    @default(0)  // 0-1
  dataPoints      Int      @default(0) // number of trades this pattern is based on
  firstObserved   DateTime @default(now())
  lastObserved    DateTime @default(now())
  metadata        String   @default("{}") // pattern-specific data
  
  trader          Trader   @relation(fields: [traderId], references: [id])
}

model CrossChainWallet {
  id              String   @id @default(cuid())
  primaryWalletId String
  linkedWalletId  String
  
  primaryChain    String   // SOL, ETH, BASE, ARB, OP, MATIC, BSC
  linkedChain     String
  linkedAddress   String
  
  linkType        String   @default("SAME_ENTITY")
  // Possible: SAME_ENTITY, LIKELY_LINKED, BRIDGE_USER, DEPOSIT_WALLET,
  //           EXCHANGE_DEPOSIT, CONTRACT_DEPLOYER, MULTI_SIG_MEMBER
  
  linkConfidence  Float    @default(0) // 0-1
  evidence        String   @default("[]") // JSON: bridge tx hashes, same EOA, etc
  bridgeTxCount   Int      @default(0)
  totalBridgedUsd Float    @default(0)
  
  primaryWallet   Trader   @relation("PrimaryWallet", fields: [primaryWalletId], references: [id])
  linkedWallet    Trader   @relation("LinkedWallet", fields: [linkedWalletId], references: [id])
  
  createdAt       DateTime @default(now())
}

model TraderLabelAssignment {
  id              String   @id @default(cuid())
  traderId        String
  label           String
  // Same labels as Trader.primaryLabel plus custom community labels
  
  source          String   @default("ALGORITHM")
  // Possible: ALGORITHM, MANUAL, COMMUNITY, ON_CHAIN_ANALYSIS,
  //           SOCIAL_CORRELATION, BRIDGE_ANALYSIS, PATTERN_MATCHING,
  //           THIRD_PARTY_API, WHITELIST
  
  confidence      Float    @default(0) // 0-1
  evidence        String   @default("[]") // JSON: list of evidence items
  assignedAt      DateTime @default(now())
  expiresAt       DateTime? // labels can expire if not reinforced
  
  trader          Trader   @relation(fields: [traderId], references: [id])
}

// ============================================================
// SIGNAL & ANALYSIS MODELS
// ============================================================

model Signal {
  id          String   @id @default(cuid())
  type        String   @default("CUSTOM")
  tokenId     String
  confidence  Int      @default(50)
  priceTarget Float?
  direction   String   @default("LONG")
  description String   @default("")
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())

  token       Token    @relation(fields: [tokenId], references: [id])
}

model UserEvent {
  id            String   @id @default(cuid())
  eventType     String   @default("OPEN_POSITION")
  tokenId       String?
  walletAddress String?
  entryPrice    Float?
  stopLoss      Float?
  takeProfit    Float?
  pnl           Float?
  createdAt     DateTime @default(now())
}

model PatternRule {
  id              String   @id @default(cuid())
  name            String
  description     String   @default("")
  category        String   @default("GENERAL")
  conditions      String   @default("{}")
  isActive        Boolean  @default(true)
  backtestResults String   @default("{}")
  winRate         Float    @default(0)
  occurrences     Int      @default(0)
  createdAt       DateTime @default(now())
}

model TokenDNA {
  id           String   @id @default(cuid())
  tokenId      String   @unique
  
  // Core DNA
  liquidityDNA String   @default("[]")
  walletDNA    String   @default("[]")
  topologyDNA  String   @default("[]")
  riskScore    Int      @default(50)
  
  // === ENRICHED TRADER INTELLIGENCE ===
  botActivityScore   Float  @default(0)  // 0-100, percentage of trading from identified bots
  smartMoneyScore    Float  @default(0)  // 0-100, smart money presence
  retailScore        Float  @default(0)  // 0-100, retail dominance
  whaleScore         Float  @default(0)  // 0-100, whale concentration
  washTradeProb      Float  @default(0)  // 0-1, probability of wash trading
  sniperPct          Float  @default(0)  // % of buyers who are known snipers
  mevPct             Float  @default(0)  // % of volume from MEV bots
  copyBotPct         Float  @default(0)  // % of volume from copy trading bots
  
  // Trader composition breakdown (JSON)
  traderComposition  String @default("{}")
  // { smartMoney: 12, whale: 3, bot_mev: 8, bot_sniper: 15, bot_copy: 5,
  //   retail: 45, creator: 1, fund: 2, influencer: 1 }
  
  // Top wallet analysis (JSON)
  topWallets         String @default("[]")
  // [{ address, label, pnl, entryRank, holdTime }]
  
  createdAt    DateTime @default(now())

  token        Token    @relation(fields: [tokenId], references: [id])
}

// ============================================================
// BIG DATA PREDICTIVE ENGINE - Capa 0
// ============================================================

model PredictiveSignal {
  id              String   @id @default(cuid())
  signalType      String   // REGIME_CHANGE, BOT_SWARM, WHALE_MOVEMENT,
                           // LIQUIDITY_DRAIN, CORRELATION_BREAK, ANOMALY,
                           // CYCLE_POSITION, SECTOR_ROTATION, MEAN_REVERSION_ZONE,
                           // SMART_MONEY_POSITIONING, VOLATILITY_REGIME
  chain           String   @default("SOL")

  tokenAddress    String?
  sector          String?  // MEME, DEFI, L1, L2, NFT, BRIDGE, STABLE

  prediction      String   @default("{}") // JSON: qué se predice
  direction       String   @default("NEUTRAL")
  confidence      Float    @default(0)    // 0-1
  timeframe       String   @default("1h")
  validUntil      DateTime?

  evidence        String   @default("[]") // JSON: datos que soportan la pred
  historicalHitRate Float  @default(0)    // % de veces que esta señal fue correcta
  dataPointsUsed  Int      @default(0)

  wasCorrect      Boolean?
  actualOutcome   String?  // JSON: qué pasó realmente

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// TRADING SYSTEMS LAB - Zona 1
// ============================================================

model TradingSystem {
  id                String   @id @default(cuid())
  name              String
  description       String?
  category          String   // ALPHA_HUNTER, SMART_MONEY, TECHNICAL,
                             // DEFENSIVE, BOT_AWARE, DEEP_ANALYSIS,
                             // MICRO_STRUCTURE, ADAPTIVE
  icon              String   @default("🎯")

  // Las 5 capas de configuración
  assetFilter       String   @default("{}")   // JSON: filtro de activos
  phaseConfig       String   @default("{}")   // JSON: fases habilitadas + config por fase
  entrySignal       String   @default("{}")   // JSON: condiciones de entrada
  executionConfig   String   @default("{}")   // JSON: cómo ejecutar
  exitSignal        String   @default("{}")   // JSON: condiciones de salida

  // Big Data context requirements
  bigDataContext    String   @default("{}")   // JSON: regime, vol, bot swarm

  // Temporalidad
  primaryTimeframe  String   @default("1h")
  confirmTimeframes String   @default("[]")

  // Risk management
  maxPositionPct    Float    @default(5)
  maxOpenPositions  Int      @default(10)
  stopLossPct       Float    @default(15)
  takeProfitPct     Float    @default(40)
  trailingStopPct   Float?
  cashReservePct    Float    @default(20)

  // Capital allocation
  allocationMethod  String   @default("KELLY_MODIFIED")
  allocationConfig  String   @default("{}")

  // State
  isActive          Boolean  @default(false)
  isPaperTrading    Boolean  @default(false)
  version           Int      @default(1)
  parentSystemId    String?

  // Auto-optimization
  autoOptimize      Boolean  @default(false)
  optimizationMethod String? // GRID, WALK_FORWARD, BAYESIAN, GENETIC, ENSEMBLE
  optimizationFreq  String?  // DAILY, WEEKLY, MONTHLY

  // Metrics (actualizadas por backtests)
  totalBacktests    Int      @default(0)
  bestSharpe        Float    @default(0)
  bestWinRate       Float    @default(0)
  bestPnlPct        Float    @default(0)
  avgHoldTimeMin    Float    @default(0)

  userId            String?  // Nullable for backward compat

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relaciones
  backtests         BacktestRun[]
  operations        BacktestOperation[]
  derivedSystems    TradingSystem[]  @relation("SystemDerivation")
  parentSystem      TradingSystem?   @relation("SystemDerivation", fields: [parentSystemId], references: [id])
  user              User?     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================================
// BACKTESTING ENGINE - Zona 2
// ============================================================

model BacktestRun {
  id                String   @id @default(cuid())
  systemId          String

  mode              String   @default("HISTORICAL")  // HISTORICAL, PAPER, FORWARD
  periodStart       DateTime
  periodEnd         DateTime
  initialCapital    Float
  capitalAllocation String   @default("{}")
  allocationMethod  String   @default("KELLY_MODIFIED")
  strategyMeta      String   @default("{}")  // JSON: strategyName, category, timeframe, tokenAgeCategory, riskTolerance

  // Results
  finalCapital      Float    @default(0)
  totalPnl          Float    @default(0)
  totalPnlPct       Float    @default(0)
  annualizedReturn  Float?
  benchmarkReturn   Float?
  alpha             Float?

  totalTrades       Int      @default(0)
  winTrades         Int      @default(0)
  lossTrades        Int      @default(0)
  winRate           Float    @default(0)

  avgWin            Float    @default(0)
  avgLoss           Float    @default(0)
  profitFactor      Float    @default(0)
  expectancy        Float    @default(0)

  maxDrawdown       Float    @default(0)
  maxDrawdownPct    Float    @default(0)
  sharpeRatio       Float    @default(0)
  sortinoRatio      Float?
  calmarRatio       Float?
  recoveryFactor    Float?

  avgHoldTimeMin    Float    @default(0)
  marketExposurePct Float    @default(0)

  // Breakdowns
  phaseResults      String   @default("{}")
  timeframeResults  String   @default("{}")
  operationTypeResults String @default("{}")
  allocationMethodResults String @default("{}")

  // Optimization
  optimizationEnabled Boolean  @default(false)
  optimizationMethod  String?
  bestParameters    String?
  optimizationScore Float?

  // Anti-overfitting
  inSampleScore     Float?
  outOfSampleScore  Float?
  walkForwardRatio  Float?

  status            String   @default("PENDING")  // PENDING, RUNNING, COMPLETED, FAILED
  progress          Float    @default(0)
  startedAt         DateTime?
  completedAt       DateTime?
  errorLog          String?

  userId            String?  // Nullable for backward compat

  createdAt         DateTime @default(now())

  system            TradingSystem  @relation(fields: [systemId], references: [id])
  operations        BacktestOperation[]
  user              User?     @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ============================================================
// PRICE CANDLES - Historical OHLCV Data Storage
// ============================================================

model PriceCandle {
  id            String   @id @default(cuid())
  tokenAddress  String
  chain         String   @default("SOL")
  timeframe     String   // "1m" | "5m" | "15m" | "1h" | "4h" | "1d"
  timestamp     DateTime // UTC open time
  open          Float
  high          Float
  low           Float
  close         Float
  volume        Float
  trades        Int      @default(0)
  source        String   @default("coingecko") // binance, coingecko, dexpaprika, database

  createdAt     DateTime @default(now())

  token         Token    @relation(fields: [tokenAddress], references: [address])

  @@unique([tokenAddress, chain, timeframe, timestamp])
  @@index([tokenAddress, timeframe, timestamp])
  @@index([chain, timeframe, timestamp])
}

// ============================================================
// TOKEN LIFECYCLE - Phase Detection & Tracking
// ============================================================

model TokenLifecycleState {
  id                String   @id @default(cuid())
  tokenAddress      String
  chain             String   @default("SOL")

  phase             String   // GENESIS | INCIPIENT | GROWTH | FOMO | DECLINE | LEGACY
  phaseProbability  Float    @default(0) // 0-1 confidence
  phaseDistribution String   @default("{}") // JSON: {genesis: 0.05, incipient: 0.1, ...}
  transitionFrom    String?  // Previous phase if transitioning
  transitionProb    Float?   // Transition probability

  signals           String   @default("{}") // JSON: input signals and their scores
  detectedAt        DateTime @default(now())

  token             Token    @relation(fields: [tokenAddress], references: [address])

  @@index([tokenAddress, detectedAt])
  @@index([phase, detectedAt])
}

// ============================================================
// TRADER BEHAVIOR MODEL - Behavioral Prediction Matrices
// ============================================================

model TraderBehaviorModel {
  id            String   @id @default(cuid())
  archetype     String   // SMART_MONEY | WHALE | SNIPER | RETAIL_FOMO |
                         // RETAIL_HOLDER | SCALPER | DEGEN | CONTRARIAN
  tokenPhase    String   // GENESIS | INCIPIENT | GROWTH | FOMO | DECLINE | LEGACY
  action        String   // BUY | SELL | HOLD | ACCUMULATE | DISTRIBUTE | WATCH
  probability   Float    @default(0) // 0-1 current estimated probability
  intensity     Float    @default(0) // expected portfolio % commitment
  duration      Float    @default(0) // expected duration in hours

  observations  Int      @default(0) // number of real observations
  confidence    Float    @default(0) // 0-1 statistical confidence
  lastUpdated   DateTime @updatedAt

  @@unique([archetype, tokenPhase, action])
  @@index([archetype, tokenPhase])
}

// ============================================================
// FEEDBACK METRICS - Continuous Learning System
// ============================================================

model FeedbackMetrics {
  id            String   @id @default(cuid())
  sourceType    String   // "signal" | "backtest" | "live_trade"
  sourceId      String   // ID of the signal, backtest run, or trade
  metricName    String   // "accuracy" | "brier_score" | "sharpe" | "win_rate" | ...
  metricValue   Float
  context       String   @default("{}") // JSON: phase, regime, token, conditions
  period        String   @default("24h") // 1h | 4h | 24h | 7d | 30d
  measuredAt    DateTime @default(now())

