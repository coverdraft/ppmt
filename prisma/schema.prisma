  tokensOperable  Int      @default(0)
  tokensTradeable Int      @default(0)

  // Best picks from this cycle
  topPicks        String   @default("[]")   // JSON: top system recommendations
  operabilitySummary String @default("{}") // JSON: {premium: N, good: N, marginal: N, ...}

  // Compound Growth Tracking
  capitalBeforeCycle Float  @default(0)
  capitalAfterCycle  Float  @default(0)
  cyclePnlUsd        Float  @default(0)
  cyclePnlPct        Float  @default(0)
