  // Cycle phases: SCAN, GENERATE, BACKTEST, EVALUATE, SAVE, EVOLVE
  currentPhase    String   @default("SCAN")
  status          String   @default("RUNNING")  // RUNNING, COMPLETED, FAILED

  // SCAN phase results
  tokensScanned   Int      @default(0)
  topTokenAddresses String @default("[]")  // JSON: top token addresses found

  // GENERATE phase results
  variantsGenerated Int    @default(0)
  variantIds      String   @default("[]")  // JSON: system IDs of generated variants

  // BACKTEST phase results
  backtestsRun    Int      @default(0)
  backtestIds     String   @default("[]")  // JSON: backtest IDs

  // EVALUATE phase results
  bestScore       Float    @default(0)
  bestSystemId    String?
  bestBacktestId  String?
  improvedCount   Int      @default(0)
  degradedCount   Int      @default(0)
  totalMutations  Int      @default(0)
  evaluationResults String @default("{}")  // JSON: full evaluation data

  // SAVE phase results (Hall of Fame)
  strategiesSavedToHof Int  @default(0)
  hofStrategyIds   String  @default("[]")  // JSON: AIBestStrategy IDs saved

  // EVOLVE phase results (mutations for next cycle)
  mutationsPrepared Int    @default(0)
  nextCycleSeedIds String  @default("[]")  // JSON: system IDs to use as seeds for next cycle

  // Paper trading activation
  strategiesActivated String @default("[]")  // JSON: system IDs activated for paper trading
  entriesExecuted    String @default("[]")  // JSON: trade IDs
  exitsProcessed     String @default("[]")  // JSON: {backtestId, exitReason, pnlUsd}[]

  // Error tracking
  errors          String   @default("[]")  // JSON: string[]
  errorLog        String?

  // Timing
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  scanDurationMs  Int      @default(0)
  generateDurationMs Int   @default(0)
  backtestDurationMs Int   @default(0)
  evaluateDurationMs Int   @default(0)
  saveDurationMs  Int      @default(0)
  evolveDurationMs Int     @default(0)
  totalDurationMs Int      @default(0)

  // Config snapshot
  configSnapshot  String   @default("{}")  // JSON: AutoEvolutionConfig used

  createdAt       DateTime @default(now())

  @@index([runId, cycleNumber])
  @@index([status, startedAt])
  @@map("evolution_cycles")
}


