    subgraph STORAGE["💾 STORAGE (SQLite + Prisma 7)"]
        DB_TOKENS["Tokens + DNA"]
        DB_TRADERS["Traders + Transactions"]
        DB_SIGNALS["Signals + Predictions"]
        DB_SESSIONS["Paper Sessions + Positions"]
        DB_BACKTEST["Backtest Runs + Operations"]
        DB_CANDLES["Price Candles (OHLCV)"]
    end

    subgraph UI["🖥️ UI DASHBOARD (React)"]
        UI_MAIN["AI Strategy Manager<br/>Main Component"]
        UI_SCAN["DNA Scanner"]
        UI_BRAIN["Brain Dashboard"]
        UI_BT["Backtesting Lab"]
        UI_PAPER["Paper Trading Panel"]
        UI_RISK["Risk Management"]
        UI_SIG["Signal Center"]
        UI_TRADE["Trade History"]
    end

    %% DATA FLOW
    EXTERNAL --> PIPELINE
    PIPELINE --> BRAIN
    PIPELINE --> STORAGE

    BRAIN --> STRATEGY
    BRAIN --> RISK
    BRAIN --> STORAGE

    STRATEGY --> EXECUTION
    RISK --> STRATEGY
    RISK --> EXECUTION

    EXECUTION --> STORAGE
    EXECUTION --> UI

    STORAGE --> BRAIN
    STORAGE --> STRATEGY
    STORAGE --> EXECUTION

    UI --> STRATEGY
    UI --> EXECUTION
    UI --> RISK
    UI --> BRAIN

