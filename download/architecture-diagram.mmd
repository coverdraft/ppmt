        DP["DexPaprika<br/>Token Discovery"]
        ES["Etherscan<br/>On-chain Data"]
    end

    subgraph PIPELINE["📥 DATA PIPELINE"]
        ING["Data Ingestion<br/>Pipeline"]
        OHLCV["OHLCV Pipeline<br/>Multi-TF Candles"]
        CACHE["Unified Cache<br/>+ Rate Limiter"]
        SEM["Request Semaphore"]
