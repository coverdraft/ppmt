        B10["10. Smart Money Tracker"]
        B11["11. Buy/Sell Pressure"]
        B12["12. Feedback Loop<br/>Continuous Learning"]
    end

    subgraph STRATEGY["🎯 STRATEGY LAYER"]
        TSE["Trading System Engine<br/>7 Built-in Templates"]
        SG["Signal Generators"]
        SE["Strategy Evolution<br/>Auto-Refinement"]
        SSM["Strategy State Manager"]
        CA["Capital Allocation<br/>16 Methods"]
        DM["Decision Engine"]
    end

    subgraph RISK["🛡️ RISK MANAGEMENT"]
        RMP["Risk Mgmt Panel<br/>Exposure + Drawdown"]
